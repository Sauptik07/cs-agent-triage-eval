# Copy this file to `.env` and fill in the values. `.env` is gitignored — never commit real keys.

# Which provider the eval runner calls. One of: deepseek, anthropic
LLM_PROVIDER=deepseek

# DeepSeek — the classifier (cross-model vs. Gemini generation, to reduce style leakage).
# https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Anthropic — the frontier data point in the cost/quality table. Run sparingly, on Haiku.
# https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Gemini is NOT an eval provider. Its free-tier throttling would corrupt the latency column,
# so it is used only by the separate, out-of-eval data-generation script.
GEMINI_API_KEY=
